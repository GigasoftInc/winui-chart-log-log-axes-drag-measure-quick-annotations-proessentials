<Window x:Class="LogLogDragMeasureWinUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pe="using:Gigasoft.ProEssentials"
        Title="ProEssentials — Log-Log Axes &amp; Quick Annotation Drag Measure">

    <!-- WinUI note: unlike WPF, Window is not a Control here. It has no Height/Width/MinWidth,
         no Loaded event, no Background and no UseLayoutRounding. The window size that used to
         live in XAML is applied in code (SizeAndCenterWindow), the background and layout
         rounding moved to the root Grid, and the chart is initialized from the CHART's Loaded
         event, never the window's. -->
    <Grid Background="#FF001A20" UseLayoutRounding="True">
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- PesgoWinUI chart                                                -->
        <!--                                                                 -->
        <!-- Mouse wheel — zoom both axes simultaneously (log-log aware)     -->
        <!-- Left-click drag — quick annotation drag measurement tool:       -->
        <!--   draws a live measurement rectangle with X and Y delta labels  -->
        <!--   overlaid on top of the cached chart via CacheBmp2             -->
        <!-- Right-click — context menu (export, print, customize)           -->
        <!--                                                                 -->
        <!-- The pointer handlers are NOT attached here. PesgoWinUI marks    -->
        <!-- PointerPressed/Moved/Released handled after it forwards them to -->
        <!-- the engine, so they are attached in code with AddHandler(...,   -->
        <!-- handledEventsToo: true). See MainWindow.xaml.cs.                -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <pe:PesgoWinUI x:Name="Pesgo1"
                       Loaded="Pesgo1_Loaded" />
    </Grid>

</Window>
